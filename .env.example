# GenLayer network the Genjury frontend should talk to.
#   testnet   — public GenLayer Testnet (Asimov). Default. Recommended.
#   studionet — local GenLayer Studio at http://localhost:4000
#   localnet  — local GenLayer Localnet
VITE_GENLAYER_NETWORK=testnet

# Optional: override the RPC URL for the chosen chain (advanced).
# VITE_GENLAYER_RPC=https://your-genlayer-rpc.example.com
