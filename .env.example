# GenLayer network the frontend talks to.
# One of: 'studionet' (default — local GenLayer Studio),
#         'localnet'  (a self-hosted localnet),
#         'testnet'   (the public Asimov testnet).
VITE_GENLAYER_NETWORK=studionet

# Optional: override the chain's default RPC endpoint.
# Studio's default RPC: http://localhost:4000/api
# VITE_GENLAYER_RPC=http://localhost:4000/api
