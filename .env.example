# ──────────────────────────────────────────────────────────────────────────────
# Genjury frontend env vars
# ──────────────────────────────────────────────────────────────────────────────

# REQUIRED — the deployed Genjury contract address (singleton, multi-room).
# The platform owner deploys `contracts/genjury.py` ONCE on the chosen network
# and pastes the address here. Players never deploy contracts; they create
# rooms inside this one via `create_room`.
VITE_GENJURY_CONTRACT=0x0000000000000000000000000000000000000000

# Optional — which GenLayer network to target. One of:
#   bradbury   (default — GenLayer Testnet Bradbury)
#   asimov     (GenLayer Testnet Asimov)
#   studionet  (local GenLayer Studio)
#   localnet   (GenLayer localnet)
VITE_GENLAYER_NETWORK=bradbury

# Optional — override the RPC URL used for reads (writes always go through the
# user's wallet). Useful if you're running your own node.
# VITE_GENLAYER_RPC=https://your-rpc.example.com
