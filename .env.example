# GenLayer network the Genjury frontend should talk to.
#   bradbury  — public GenLayer Testnet (Bradbury). Default. Recommended.
#   asimov    — public GenLayer Testnet (Asimov).
#   studionet — local GenLayer Studio at http://localhost:4000
#   localnet  — local GenLayer Localnet
VITE_GENLAYER_NETWORK=bradbury

# Optional: override the RPC URL for the chosen chain (advanced).
# VITE_GENLAYER_RPC=https://your-genlayer-rpc.example.com

# ─── Default Genjury contract (the "house room") ──────────────────────────────
# Paste the address of a Genjury contract you've already deployed in the
# GenLayer Studio. Players will see it as a "Featured room" on the landing
# page and be one click away from joining it without deploying their own.
#
# In Vercel: Project → Settings → Environment Variables → add
#   Name:  VITE_GENJURY_DEFAULT_CONTRACT
#   Value: 0xYourDeployedGenjuryContractAddress
#   Scope: Production, Preview, Development (tick all three)
# Then redeploy so Vite re-bundles with the new value baked in.
#
# Leave empty to disable the featured-room shortcut.
VITE_GENJURY_DEFAULT_CONTRACT=
