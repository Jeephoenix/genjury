{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/"
    }
  ],
  "crons": [
    {
      "path": "/api/chat-cleanup",
      "schedule": "0 3 * * *"
    }
  ],
  "functions": {
    "api/chat.js": {
      "maxDuration": 10
    },
    "api/chat-cleanup.js": {
      "maxDuration": 10
    },
    "api/faucet.js": {
      "maxDuration": 15
    }
  }
}
