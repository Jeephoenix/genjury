{
  "outputDirectory": "artifacts/genjury/dist/public",
  "buildCommand": "pnpm install --no-frozen-lockfile && pnpm --filter @workspace/genjury run build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "env": {
    "NODE_VERSION": "20"
  }
}
